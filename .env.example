# =============================================================================
# ERP AI – Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# PostgreSQL
POSTGRES_DB=erp_ai
POSTGRES_USER=erp_admin
POSTGRES_PASSWORD=change_me_in_production

# Kafka
KAFKA_BROKERS=kafka:9092

# Application
APP_HOST=0.0.0.0
APP_PORT=3000
RUST_LOG=info

# JWT
JWT_SECRET=change-me-in-production

# Database URL (constructed from above, used by SQLx)
DATABASE_URL=postgres://erp_admin:change_me_in_production@postgres:5432/erp_ai

# AI Configuration
# Options: gemini (default), ollama, openai
AI_PROVIDER=gemini

# Google AI (Gemini)
GOOGLE_AI_KEY=AIzaSyDkmgOUCHs5U9c1UeqyTC8ori8k8_uw8Os
# Ollama (Local AI)
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Redis
REDIS_URL=redis://redis:6379
